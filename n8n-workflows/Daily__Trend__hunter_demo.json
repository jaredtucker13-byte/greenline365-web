    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// IRON DOME VIBE CHECK PROTOCOL (v2.0)\n\n// 1. Get the text from the AI Agent\nconst generatedText =\n  $input.item.json.output ||\n  $input.item.json.text ||\n  \"\";\n\n// 2. Define the rules\nconst constraints = {\n  forbidden_words: [\n    \"synergy\",\n    \"blast\",\n    \"skyrocket\",\n    \"guaranteed\",\n    \"100%\",\n    \"crypto\",\n    \"investment\"\n  ],\n  copyright_risks: [\n    \"disney\",\n    \"marvel\",\n    \"star wars\",\n    \"mickey mouse\",\n    \"nike\",\n    \"nintendo\"\n  ]\n};\n\n// 3. Scan the text\nlet violations = [];\nconst textLower = generatedText.toLowerCase();\n\n// Scan for forbidden words\nfor (const word of constraints.forbidden_words) {\n  if (textLower.includes(word.toLowerCase())) {\n    violations.push(`Forbidden Word: \"${word}\"`);\n  }\n}\n\n// Scan for copyright risks\nfor (const brand of constraints.copyright_risks) {\n  if (textLower.includes(brand)) {\n    violations.push(`Copyright Risk: \"${brand}\"`);\n  }\n}\n\n// 4. Decision logic\nconst hasViolations = violations.length > 0;\n\n// 5. Build base payload (keep everything that came in)\nconst base = {\n  ...$json,\n  generatedText\n};\n\nif (hasViolations) {\n  // REJECT\n  return {\n    json: {\n      ...base,\n      status: \"REJECTED\",\n      reason: violations.join(\", \"),\n      original_text: generatedText,\n      vibeCheck: {\n        approved: false,\n        violations\n      }\n    }\n  };\n} else {\n  // APPROVE\n  return {\n    json: {\n      ...base,\n      status: \"APPROVED\",\n      final_text: generatedText,\n      timestamp: new Date().toISOString(),\n      vibeCheck: {\n        approved: true,\n        violations: []\n      }\n    }\n  };\n}"
      },
      "id": "8dc711e4-38e2-463e-8a90-08daa46127ce",
      "name": "Vibe rules",
