    {
      "parameters": {
        "schemaType": "manual",
        "inputSchema": "{\n  \"type\": \"object\",\n  \"required\": [\"tenant_id\", \"lead_id\", \"dynamic_variables\"],\n  \"properties\": {\n    \"tenant_id\": { \"type\": \"string\" },\n    \"lead_id\": { \"type\": \"string\" },\n\n    \"company\": {\n      \"type\": \"object\",\n      \"required\": [\"name\", \"website_url\", \"phone\", \"email\", \"location\", \"industry\"],\n      \"properties\": {\n        \"name\": { \"type\": [\"string\", \"null\"] },\n        \"website_url\": { \"type\": [\"string\", \"null\"] },\n        \"phone\": { \"type\": [\"string\", \"null\"] },\n        \"email\": { \"type\": [\"string\", \"null\"] },\n        \"industry\": { \"type\": [\"string\", \"null\"] },\n        \"location\": {\n          \"type\": \"object\",\n          \"required\": [\"city\", \"state\", \"zip_code\"],\n          \"properties\": {\n            \"city\": { \"type\": [\"string\", \"null\"] },\n            \"state\": { \"type\": [\"string\", \"null\"] },\n            \"zip_code\": { \"type\": [\"string\", \"null\"] }\n          }\n        }\n      }\n    },\n\n    \"enrichment\": {\n      \"type\": \"object\",\n      \"required\": [\"weather\", \"local_intel\", \"common_pain_points\"],\n      \"properties\": {\n        \"weather\": {\n          \"type\": \"object\",\n          \"required\": [\"summary\", \"temp_f\", \"source\", \"as_of\"],\n          \"properties\": {\n            \"summary\": { \"type\": [\"string\", \"null\"] },\n            \"temp_f\": { \"type\": [\"number\", \"null\"] },\n            \"source\": { \"type\": [\"string\", \"null\"] },\n            \"as_of\": { \"type\": [\"string\", \"null\"] }\n          }\n        },\n        \"local_intel\": {\n          \"type\": \"object\",\n          \"required\": [\"area_summary\", \"top_topics\", \"sources\"],\n          \"properties\": {\n            \"area_summary\": { \"type\": [\"string\", \"null\"] },\n            \"top_topics\": {\n              \"type\": \"array\",\n              \"items\": { \"type\": \"string\" }\n            },\n            \"sources\": {\n              \"type\": \"array\",\n              \"items\": {\n                \"type\": \"object\",\n                \"required\": [\"title\", \"publisher\", \"url\", \"published_at\", \"evidence_snippet\"],\n                \"properties\": {\n                  \"title\": { \"type\": [\"string\", \"null\"] },\n                  \"publisher\": { \"type\": [\"string\", \"null\"] },\n                  \"url\": { \"type\": [\"string\", \"null\"] },\n                  \"published_at\": { \"type\": [\"string\", \"null\"] },\n                  \"evidence_snippet\": { \"type\": [\"string\", \"null\"] }\n                }\n              }\n            }\n          }\n        },\n        \"common_pain_points\": {\n          \"type\": \"array\",\n          \"minItems\": 3,\n          \"items\": {\n            \"type\": \"object\",\n            \"required\": [\"pain_key\", \"pain_title\", \"why_it_matters\", \"evidence\"],\n            \"properties\": {\n              \"pain_key\": { \"type\": \"string\" },\n              \"pain_title\": { \"type\": \"string\" },\n              \"why_it_matters\": { \"type\": \"string\" },\n              \"evidence\": {\n                \"type\": \"array\",\n                \"items\": {\n                  \"type\": \"object\",\n                  \"required\": [\"title\", \"publisher\", \"url\", \"published_at\", \"metric_or_finding\", \"evidence_snippet\"],\n                  \"properties\": {\n                    \"title\": { \"type\": [\"string\", \"null\"] },\n                    \"publisher\": { \"type\": [\"string\", \"null\"] },\n                    \"url\": { \"type\": [\"string\", \"null\"] },\n                    \"published_at\": { \"type\": [\"string\", \"null\"] },\n                    \"metric_or_finding\": { \"type\": [\"string\", \"null\"] },\n                    \"evidence_snippet\": { \"type\": [\"string\", \"null\"] }\n                  }\n                }\n              }\n            }\n          }\n        }\n      }\n    },\n\n    \"dynamic_variables\": {\n      \"type\": \"object\",\n      \"required\": [\"self_reference\", \"confirmation_script\", \"opener\", \"pain_point_hooks\", \"nepq_questions\", \"cta\"],\n      \"properties\": {\n        \"self_reference\": { \"type\": \"string\" },\n        \"confirmation_script\": { \"type\": \"string\" },\n        \"opener\": { \"type\": \"string\" },\n        \"pain_point_hooks\": {\n          \"type\": \"array\",\n          \"minItems\": 3,\n          \"items\": {\n            \"type\": \"object\",\n            \"required\": [\"pain_key\", \"one_liner\"],\n            \"properties\": {\n              \"pain_key\": { \"type\": \"string\" },\n              \"one_liner\": { \"type\": \"string\" }\n            }\n          }\n        },\n        \"nepq_questions\": {\n          \"type\": \"array\",\n          \"items\": {\n            \"type\": \"object\",\n            \"required\": [\"type\", \"question\"],\n            \"properties\": {\n              \"type\": { \"type\": \"string\" },\n              \"question\": { \"type\": \"string\" }\n            }\n          }\n        },\n        \"cta\": { \"type\": \"string\" }\n      }\n    }\n  }\n}"
