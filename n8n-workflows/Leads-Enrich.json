        "jsonOutput": "{\n  \"canonical\": {\n    \"id\": \"={{ $now.toISO() + '-' + $('Webhook').item.json.body.email.split('@')[0] }}\",\n    \"trace_id\": \"={{ $uuid() }}\",\n    \"event_id\": \"={{ $uuid() }}\",\n    \"tenant_id\": \"={{ $('Webhook').item.json.body.tenant_id }}\",\n    \"source\": \"web_form\",\n    \"name\": \"={{ $('Webhook').item.json.body.name }}\",\n    \"first_name\": \"={{ $('Webhook').item.json.body.name.split(' ')[0] }}\",\n    \"email\": \"={{ $('Webhook').item.json.body.email }}\",\n    \"phone\": \"={{ $('Webhook').item.json.body.phone }}\",\n    \"company\": \"={{ $('Webhook').item.json.body.company }}\",\n    \"industry\": \"={{ $('Webhook').item.json.body.industry || 'General' }}\",\n    \"location\": {\n      \"zip_code\": \"={{ $('Webhook').item.json.body.zip_code || '' }}\",\n      \"city\": \"={{ $('Webhook').item.json.body.city || '' }}\",\n      \"state\": \"={{ $('Webhook').item.json.body.state || '' }}\",\n      \"lat\": null,\n      \"lng\": null,\n      \"timezone\": null\n    },\n    \"consent\": {\n      \"marketing\": \"={{ $('Webhook').item.json.body.consent_marketing === true || $('Webhook').item.json.body.consent_marketing === 'yes' }}\",\n      \"timestamp\": \"={{ $now.toISO() }}\"\n    },\n    \"stage\": \"New\",\n    \"score\": 0,\n    \"intent\": \"={{ $('Webhook').item.json.body.message || '' }}\",\n    \"created_at\": \"={{ $now.toISO() }}\",\n    \"updated_at\": \"={{ $now.toISO() }}\"\n  },\n  \"enrichment\": {\n    \"weather\": null,\n    \"local_events\": null,\n    \"persona_hints\": null,\n    \"school_calendar\": null,\n    \"confidence_scores\": {}\n  },\n  \"_raw\": \"={{ $('Webhook').item.json }}\"\n}",
