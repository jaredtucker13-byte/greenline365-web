# ============================================
# Greenline365 Web App — Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local — it is already in .gitignore.
#
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# All others are server-side only.

# ─── Supabase ───────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=           # e.g. https://xxxx.supabase.co  (pgbouncer=true is appended automatically by lib/supabase/server.ts)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # Server-only. Never expose to client.

# ─── Site ────────────────────────────────────
NEXT_PUBLIC_SITE_URL=               # e.g. https://greenline365.com

# ─── AI / LLM ───────────────────────────────
OPENROUTER_API_KEY=

# ─── Email ───────────────────────────────────
GMAIL_USER=
GMAIL_APP_PASSWORD=
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# ─── Payments ────────────────────────────────
STRIPE_SECRET_KEY=

# ─── Phone / Voice ───────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_VERIFY_SERVICE_SID=
RETELL_API_KEY=
RETELL_OUTBOUND_NUMBER=

# ─── Calendar (Cal.com) ─────────────────────
CALCOM_API_KEY=
CALCOM_API_URL=                     # e.g. https://api.cal.com/v1
CALCOM_EVENT_TYPE_ID=
CALCOM_USERNAME=

# ─── Email Sender ──────────────────────────────
SENDER_EMAIL=                        # e.g. noreply@greenline365.com (used by /api/email/send)
OWNER_EMAIL=                         # Owner email for weekly recap reports

# ─── N8N Webhooks ─────────────────────────────
N8N_OTP_WEBHOOK_URL=                 # N8N webhook URL for OTP delivery
N8N_TREND_WEBHOOK_URL=               # N8N webhook URL for trend data

# ─── Business ─────────────────────────────────
BUSINESS_ID=                         # Default business ID for single-tenant operations
GOOGLE_PLACES_API_KEY=               # Google Places API for CRM enrichment

# ─── Error Tracking (Sentry) ──────────────────
SENTRY_DSN=                          # e.g. https://key@o123456.ingest.sentry.io/456789
SENTRY_ENVIRONMENT=                  # auto-detected from NEXT_PUBLIC_ENVIRONMENT if not set

# ─── Rate Limiting (Upstash Redis) ───────────
UPSTASH_REDIS_REST_URL=              # e.g. https://xxx.upstash.io  (falls back to in-memory if not set)
UPSTASH_REDIS_REST_TOKEN=

# ─── Misc ────────────────────────────────────
OPENWEATHER_API_KEY=
KIE_API_KEY=
CRON_SECRET=                        # Used to protect cron job endpoints

# ─── Vercel Environment Separation ─────────
# IMPORTANT: In the Vercel Dashboard (Settings → Environment Variables),
# scope each variable to the correct target:
#   - Production:  Point NEXT_PUBLIC_SUPABASE_URL to your PRODUCTION Supabase project
#   - Preview:     Point NEXT_PUBLIC_SUPABASE_URL to a STAGING Supabase project (or the same one, with care)
#   - Development: Use .env.local for local dev
#
# Also set NEXT_PUBLIC_ENVIRONMENT per target:
#   Production  → "production"
#   Preview     → "preview"
#   Development → "development"
NEXT_PUBLIC_ENVIRONMENT=development
