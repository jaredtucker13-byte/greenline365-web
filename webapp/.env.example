# ============================================================
# GreenLine365 Environment Variables
# Copy to .env.local and fill in values
# ============================================================

# ─── Supabase ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://rawlqwjdfzicjepzmcng.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=           # Public anon key (safe for client)
SUPABASE_SERVICE_ROLE_KEY=               # Service role key (SERVER ONLY - bypasses RLS)

# ─── Stripe ───────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...            # Stripe secret key
STRIPE_WEBHOOK_SECRET=whsec_...          # Stripe webhook signing secret

# ─── Twilio (SMS / Voice) ────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_PHONE_NUMBER=
TWILIO_VERIFY_SERVICE_SID=

# ─── Retell AI (Voice Agents) ────────────────────────────
RETELL_API_KEY=
RETELL_DEMO_AGENT_ID=
RETELL_SALES_AGENT_ID=
RETELL_SUPPORT_AGENT_ID=
RETELL_FOLLOWUP_AGENT_ID=
RETELL_OUTBOUND_NUMBER=

# ─── Email ────────────────────────────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
GMAIL_USER=                              # Fallback email sender
GMAIL_APP_PASSWORD=                      # Gmail app-specific password
SENDER_EMAIL=                            # Default from address

# ─── AI / LLM ────────────────────────────────────────────
OPENROUTER_API_KEY=                      # Primary AI gateway (Claude, Gemini, etc.)
OPENAI_API_KEY=                          # OpenAI direct (if needed)

# ─── Google APIs ──────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=         # Google Maps Embed API (client-side)
GOOGLE_PLACES_API_KEY=                   # Places API for directory
OPENWEATHER_API_KEY=                     # RealFeel weather data

# ─── Cal.com (Scheduling) ────────────────────────────────
CALCOM_API_KEY=
CALCOM_EVENT_TYPE_ID=
CALCOM_USERNAME=

# ─── Design / Creative Studio ────────────────────────────
KIE_API_KEY=                             # KIE.ai design generation

# ─── URLs ─────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000   # Public-facing site URL
NEXT_PUBLIC_APP_URL=http://localhost:3000    # App URL (may differ in staging)
# VERCEL_URL is auto-set by Vercel

# ─── Security / System ───────────────────────────────────
CRON_SECRET=                             # Bearer token for cron/system audit endpoints
MCP_PLAYWRIGHT_URL=                      # Playwright MCP server URL (optional)
